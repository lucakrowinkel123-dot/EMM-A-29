    dict["mineSequenceState"] = ((int)mineSequenceState).ToString();
    dict["minerPathCompleteReceived"] = minerPathCompleteReceived ? "1" : "0";
    dict["mineStationaryTicks"] = mineStationaryTicks.ToString();
    Storage = BuildStorageFromKeyValues(dict);
}

Dictionary<string, string> ParseStorageKeyValues(string data)
{
    var dict = new Dictionary<string, string>();
    if (string.IsNullOrWhiteSpace(data))
        return dict;

    foreach (string line in data.Split(new[] { '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries))
    {
        int eq = line.IndexOf('=');
        if (eq < 0) continue;
        dict[line.Substring(0, eq).Trim()] = line.Substring(eq + 1).Trim();
    }
    return dict;
}

string BuildStorageFromKeyValues(Dictionary<string, string> dict)
{
    var sb = new StringBuilder();
    foreach (var kv in dict)
        sb.AppendLine(kv.Key + "=" + kv.Value);
    return sb.ToString();
}

void LoadState()
{
    string data = Storage;
    if (string.IsNullOrWhiteSpace(data)) return;

    var dict = new Dictionary<string, string>();
    foreach (string line in data.Split(new[] { '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries))
    {
        int eq = line.IndexOf('=');
        if (eq < 0) continue;
        dict[line.Substring(0, eq).Trim()] = line.Substring(eq + 1).Trim();
    }

    string s;
    int n;
    double d;
    Vector3D v;

    if (dict.TryGetValue("autopilotEnabled",   out s)) autopilotEnabled   = s == "1";
    if (dict.TryGetValue("hasTarget",           out s)) hasTarget           = s == "1";
    if (dict.TryGetValue("targetPosition",      out s) && TryParseV3(s, out v)) targetPosition  = v;
    if (dict.TryGetValue("desiredForward",      out s) && TryParseV3(s, out v)) desiredForward  = v;
    if (dict.TryGetValue("desiredUp",           out s) && TryParseV3(s, out v)) desiredUp       = v;
    if (dict.TryGetValue("activeMaxSpeed",      out s) && double.TryParse(s, out d)) activeMaxSpeed = d;
    if (dict.TryGetValue("pathMode",            out s)) pathMode            = s == "1";
    if (dict.TryGetValue("pathPaused",          out s)) pathPaused          = s == "1";
    if (dict.TryGetValue("pathPausedNavResume", out s)) pathPausedNavResume = s == "1";
    if (dict.TryGetValue("pathIndex",           out s) && int.TryParse(s, out n)) pathIndex = n;

    int pathCount = 0;
    if (dict.TryGetValue("pathCount", out s) && int.TryParse(s, out pathCount) && pathCount > 0)
    {
        pathRecords = new List<string>(pathCount);
        for (int i = 0; i < pathCount; i++)
        {
            if (dict.TryGetValue("pathRecord" + i, out s))
                pathRecords.Add(s);
        }
    }
    if (dict.TryGetValue("mineSequenceState", out s) && int.TryParse(s, out n)) mineSequenceState = (MineSequenceState)n;
    if (dict.TryGetValue("mineAsteroidNum", out s) && int.TryParse(s, out n)) mineAsteroidNum = n;
    if (dict.TryGetValue("mineSavedPos", out s) && TryParseV3(s, out v)) mineSavedPos = v;
    if (dict.TryGetValue("mineSavedForward", out s) && TryParseV3(s, out v)) mineSavedForward = v;
    if (dict.TryGetValue("mineSavedUp", out s) && TryParseV3(s, out v)) mineSavedUp = v;
    if (dict.TryGetValue("mineFrontApproachPoint", out s) && TryParseV3(s, out v)) mineFrontApproachPoint = v;
    if (dict.TryGetValue("minerPathCompleteReceived", out s)) minerPathCompleteReceived = s == "1";
    if (dict.TryGetValue("mineStationaryTicks", out s) && int.TryParse(s, out n)) mineStationaryTicks = n;
    if (dict.TryGetValue("fullAutoEnabled", out s)) fullAutoEnabled = s == "1";
    fullAutoWaitingForMine = false;
    fullAutoActiveAsteroid = 0;
    fullAutoCooldownTicks = 0;
}

// ---- Parse helpers ----

bool TryParseGpsCommand(string command, out Vector3D gps, out Vector3D forward, out Vector3D up)
{
    gps     = Vector3D.Zero;
    forward = Vector3D.Zero;
    up      = Vector3D.Zero;

    string[] parts     = command.Split('|');
    string gpsPart     = parts[0];
    string[] gpsTokens = gpsPart.Split(':');
    if (gpsTokens.Length < 5) return false;

    double x, y, z;
    if (!double.TryParse(gpsTokens[2], out x) || !double.TryParse(gpsTokens[3], out y) || !double.TryParse(gpsTokens[4], out z))
        return false;

    gps = new Vector3D(x, y, z);

    if (parts.Length > 1)
    {
        string[] modes = parts[1].Split(new[] { ',' }, StringSplitOptions.RemoveEmptyEntries);
        if (modes.Length == 6)
        {
            double ux, uy, uz, fx, fy, fz;
            if (double.TryParse(modes[0].Trim(), out ux) &&
                double.TryParse(modes[1].Trim(), out uy) &&
                double.TryParse(modes[2].Trim(), out uz) &&
                double.TryParse(modes[3].Trim(), out fx) &&
                double.TryParse(modes[4].Trim(), out fy) &&
                double.TryParse(modes[5].Trim(), out fz))
            {
                up      = new Vector3D(ux, uy, uz);
                forward = new Vector3D(fx, fy, fz);
                if (up.LengthSquared() > 0.001)      up      = Vector3D.Normalize(up);
                if (forward.LengthSquared() > 0.001) forward = Vector3D.Normalize(forward);
                return true;
            }
        }

        Vector3D toTarget = gps - rc.GetPosition();
        foreach (string rawMode in modes)
        {
            string mode = rawMode.Trim().ToLower();
            if (mode == "faceforward")
            {
                if (toTarget.LengthSquared() > 0.001)
                    forward = Vector3D.Normalize(toTarget);
            }
            else if (mode == "faceup")
            {
                Vector3D gravity = rc.GetNaturalGravity();
                if (gravity.LengthSquared() > 0.001)
                    up = Vector3D.Normalize(-gravity);
                else
                    up = rc.WorldMatrix.Up;
            }
        }
    }
    return true;
}

bool TryParseVector3(string csv, out Vector3D value)
{
    value = Vector3D.Zero;
    string[] t = csv.Split(',');
    if (t.Length != 3) return false;
    double x, y, z;
    if (!double.TryParse(t[0].Trim(), out x) || !double.TryParse(t[1].Trim(), out y) || !double.TryParse(t[2].Trim(), out z))
        return false;
    value = new Vector3D(x, y, z);
    return true;
}

