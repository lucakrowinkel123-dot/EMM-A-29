// Carrier autopilot for EMM-A system.
// Broadcasts dock connector pose and supports nav/path autopilot.
//
// ============= Commands ==============
// Nav;GPS:Name:X:Y:Z:|Ux,Uy,Uz,Fx,Fy,Fz : set target position and orientation vectors
// Nav;GPS:Name:X:Y:Z:|Faceup,Faceforward  : auto-derive up/forward toward target
// stop         : disable autopilot and release controls
// start        : enable autopilot (requires a target)
// reset        : clear target and all path state
// dumpgps      : save current GPS + orientation to Custom Data
// pathstart    : load records from "Carrier Path" timer and execute row-by-row
// pathpause    : pause path execution
// pathcontinue : resume path after pause
// pathstop     : stop path mode and clear queued records
// TOFF r,u,f   : set target offset in local Right,Up,Forward meters
// TOFFRESET    : reset target offset to 0,0,0
// saveasteroid : simulate recompile, then save carrier pos, miner ore totals, and miner
//                path into the next Asteroid Record slot across "EMM-A Ca Asteroid DB Axx"
//                timers (asteroidsPerDb records each). Also updates "EMM-A Ca Zone DB"
//                with ore list + status (saved as Complete). Sends PathClear to miner.
// Missing ore names are auto-added to timer "EMM-A Ca Ores" custom data
// in format: <OreName> on
// <OreName> on/off : set one ore row state in "EMM-A Ca Ores" (example: Iron off)
// Fullauto     : auto-select nearest Open asteroid with enabled ore(s) and run Mine loop
// Fullautostop : stop Fullauto loop (does not forcibly cancel an in-progress Mine step)
// setallopen   : set all asteroid status lines in Zone DB to "Open" (adds missing lines).
// LoadAsteroid <n> : load the path records from the saved Asteroid record <n> (e.g. 002)
//                    into the miner's "EMM-A Mi Path" timer, replacing its current content.
// GoTo <n>         : approach saved Asteroid <n> from a safe side-point, then fly/align to saved
//                    carrier pose while avoiding the asteroid bubble around the saved site.
// Mine <n>         : orchestrates GoTo <n> -> LoadAsteroid <n> -> miner PathStart -> wait for miner
//                    path completion broadcast -> move to front approach point and finish.
// =====================================

// ========== Editable Script Settings ==========
string carrierConnectorName   = "EMM-A Ca Connector";
string carrierRemoteName      = "EMM-A Ca Remote Control";
string dockBroadcastTag       = "EMM_A_DOCK_POSE";
string minerPathCompleteTag   = "EMM_A_MINER_PATH_COMPLETE";
double broadcastForwardOffset = 1.25;
UpdateFrequency tickSpeed     = UpdateFrequency.Update1;
double maxSpeed               = 25;
double arrivalTolerance       = 2.5;
double orientationToleranceDeg = 1.0;
string pathTimerTag           = "Carrier Path";
double TOFFR = 0;
double TOFFU = 0;
double TOFFF = 0;

// ----- SaveAsteroid settings -----
int    asteroidsPerDb    = 5;                      // how many Asteroid Records per DB timer
string minerPathTimerTag = "EMM-A Mi Path";        // name tag of the miner's Path timer
string asteroidDbTagPfx  = "EMM-A Ca Asteroid DB "; // prefix for Asteroid DB timer names
string zoneDbTimerTag    = "EMM-A Ca Zone DB";     // exact name of the Zone DB timer
string oreNameTimerTag   = "EMM-A Ca Ores";        // exact name of timer storing ore on/off rows
string minerContainerTag = "EMM-A Mi ";            // name tag for miner cargo containers
string minerPbTag        = "EMM-A Mi Prog. Block (Miner)";          // name tag for the miner's programmable block
string asteroidHeaderLine = "------------------------------------------------------------------------------------------------";
double goToLeadDistanceMeters = 1000;
double goToBubbleOffsetMeters = 150;
double goToBubbleRadiusMeters = 750;
int fullAutoRetryTicks = 180; // retries when no valid Fullauto target is available
double mineStationarySpeedMps = 0.20;
int mineStationaryConfirmTicks = 30;
string indicatorLightName = "EMM-A Ca Indicator light";
double indicatorLightDelaySeconds = 0.5;
// =============================================

IMyShipController rc;
ThrusterControl thrust;
GyroControl gyros;
IMyShipConnector carrierConnector;
IMyLightingBlock indicatorLight;
List<IMyGyro>   allGyros     = new List<IMyGyro>();
List<IMyThrust> allThrusters = new List<IMyThrust>();
int indicatorDelayTicksRemaining = 0;
enum IndicatorTransitionState { None, WaitEnableAfterColor, WaitNeutralAfterDisable }
IndicatorTransitionState indicatorTransition = IndicatorTransitionState.None;
readonly Color indicatorAutopilotColor = new Color(0, 200, 255);
readonly Color indicatorNeutralColor = Color.White;

Vector3D targetPosition  = Vector3D.Zero;
bool hasTarget           = false;
bool autopilotEnabled    = false;
Vector3D desiredForward  = Vector3D.Zero;
Vector3D desiredUp       = Vector3D.Zero;
double activeMaxSpeed    = 0;

bool pathMode            = false;
bool pathPaused          = false;
bool pathPausedNavResume = false;
List<string> pathRecords = new List<string>();
int pathIndex            = 0;

double secondsPerTick  = 1.0 / 60.0;
readonly int echoFrequency = 100;
int runtime            = 0;
double runtimePeakLastMinuteMs = 0;
double runtimePeakWindowElapsedSeconds = 0;
IMyTimerBlock _cachedPathTimer;
IMyTimerBlock _cachedZoneDbTimer;

bool goToMode = false;
int goToStage = 0; // 1 = flying to safe side-point, 2 = final approach to saved carrier pose
IMyBroadcastListener minerPathCompleteListener;

enum MineSequenceState
{
    None,
    GoingTo,
    WaitingForStationary,
    WaitingMinerPathComplete,
    ReturningToFrontApproach
}

MineSequenceState mineSequenceState = MineSequenceState.None;
int mineAsteroidNum = 0;
Vector3D mineSavedPos = Vector3D.Zero;
Vector3D mineSavedForward = Vector3D.Zero;
Vector3D mineSavedUp = Vector3D.Zero;
Vector3D mineFrontApproachPoint = Vector3D.Zero;
bool minerPathCompleteReceived = false;
int mineStationaryTicks = 0;

bool fullAutoEnabled = false;
bool fullAutoWaitingForMine = false;
int fullAutoCooldownTicks = 0;
int fullAutoActiveAsteroid = 0;

class ZoneAsteroidRecord
{
    public int Number;
    public Vector3D Position;
    public List<string> Ores = new List<string>();
    public string Status = "";
}

public Program()
{
    rc = GridTerminalSystem.GetBlockWithName(carrierRemoteName) as IMyRemoteControl;
    if (rc == null)
        rc = GetBlock<IMyRemoteControl>();
    if (rc == null)
        throw new Exception("No remote control found. Set carrierRemoteName.");

    carrierConnector = GridTerminalSystem.GetBlockWithName(carrierConnectorName) as IMyShipConnector;
    indicatorLight = GridTerminalSystem.GetBlockWithName(indicatorLightName) as IMyLightingBlock;

    allGyros     = GetBlocks<IMyGyro>().FindAll(b => HasCarrierTag(b));
    allThrusters = GetBlocks<IMyThrust>().FindAll(b => HasCarrierTag(b));
    thrust = new ThrusterControl(rc, tickSpeed, allThrusters);
    gyros  = new GyroControl(rc, tickSpeed, allGyros);

    if (tickSpeed == UpdateFrequency.Update10)
        secondsPerTick = 10.0 / 60.0;
    else if (tickSpeed == UpdateFrequency.Update100)
        secondsPerTick = 100.0 / 60.0;

    LoadState();
    minerPathCompleteListener = IGC.RegisterBroadcastListener(minerPathCompleteTag);
    Echo("Ready.");
    Runtime.UpdateFrequency = tickSpeed;
}

void ResetMovement()
{
    gyros.Reset();
    thrust.Reset();
}

public void Main(string argument, UpdateType updateSource)
{
    if (updateSource == UpdateType.Update1 || updateSource == UpdateType.Update10 || updateSource == UpdateType.Update100)
    {
        UpdateRuntimeMetrics();
        if (carrierConnector == null)
            carrierConnector = GridTerminalSystem.GetBlockWithName(carrierConnectorName) as IMyShipConnector;

        BroadcastDockPose();
        PollMinerPathCompletion();

        if (runtime % echoFrequency == 0)
        {
            WriteEcho();
            SaveStateProgressOnly();
        }

        if (autopilotEnabled && hasTarget)
            Move();
        else
            ResetMovement();

        UpdateGoToRunner();
        UpdateMineSequence();
        UpdateFullAuto();
        UpdatePathRunner();
        UpdateIndicatorLight();
        runtime++;
    }
    else
    {
        RemoteCommand(argument);
        SaveState();
    }
}

int GetIndicatorDelayTicks()
{
    return Math.Max(1, (int)Math.Ceiling(indicatorLightDelaySeconds / Math.Max(0.001, secondsPerTick)));
}

void UpdateIndicatorLight()
{
    if (indicatorLight == null)
        indicatorLight = GridTerminalSystem.GetBlockWithName(indicatorLightName) as IMyLightingBlock;
    if (indicatorLight == null)
        return;

    bool desiredOn = autopilotEnabled;
    Color desiredOnColor = indicatorAutopilotColor;

    if (desiredOn)
    {
        if (indicatorTransition == IndicatorTransitionState.WaitNeutralAfterDisable)
        {
            indicatorTransition = IndicatorTransitionState.None;
            indicatorDelayTicksRemaining = 0;
        }

        if (!indicatorLight.Enabled)
        {
            if (indicatorTransition != IndicatorTransitionState.WaitEnableAfterColor)
            {
                indicatorLight.Color = desiredOnColor; // set color first
                indicatorDelayTicksRemaining = GetIndicatorDelayTicks();
                indicatorTransition = IndicatorTransitionState.WaitEnableAfterColor;
            }
            else
            {
                indicatorLight.Color = desiredOnColor;
                indicatorDelayTicksRemaining--;
                if (indicatorDelayTicksRemaining <= 0)
                {
                    indicatorLight.Enabled = true; // turn on after delay
                    indicatorTransition = IndicatorTransitionState.None;
                }
            }
        }
        else
        {
            indicatorLight.Color = desiredOnColor;
            indicatorTransition = IndicatorTransitionState.None;
            indicatorDelayTicksRemaining = 0;
        }
        return;
    }

    if (indicatorTransition == IndicatorTransitionState.WaitEnableAfterColor)
    {
        indicatorTransition = IndicatorTransitionState.None;
        indicatorDelayTicksRemaining = 0;
    }

    if (indicatorLight.Enabled)
    {
        indicatorLight.Enabled = false; // turn off first
        indicatorDelayTicksRemaining = GetIndicatorDelayTicks();
        indicatorTransition = IndicatorTransitionState.WaitNeutralAfterDisable;
        return;
    }

    if (indicatorTransition == IndicatorTransitionState.WaitNeutralAfterDisable)
    {
        indicatorDelayTicksRemaining--;
        if (indicatorDelayTicksRemaining <= 0)
        {
            indicatorLight.Color = indicatorNeutralColor; // set neutral after off delay
            indicatorTransition = IndicatorTransitionState.None;
        }
        return;
    }

    indicatorLight.Color = indicatorNeutralColor;
}

void BroadcastDockPose()
{
    if (carrierConnector == null)
        return;
    MatrixD m    = carrierConnector.WorldMatrix;
    Vector3D pos = carrierConnector.GetPosition();
    Vector3D f   = Vector3D.Normalize(m.Forward);
    Vector3D u   = Vector3D.Normalize(m.Up);
    pos += f * broadcastForwardOffset;
    string payload = ToCsv(pos) + "|" + ToCsv(f) + "|" + ToCsv(u);
    IGC.SendBroadcastMessage(dockBroadcastTag, payload);
}

string ToCsv(Vector3D v)
{
    return v.X.ToString("0.000") + "," + v.Y.ToString("0.000") + "," + v.Z.ToString("0.000");
}

void WriteEcho()
{
    StringBuilder sb = new StringBuilder();
    sb.AppendLine("Autopilot Mode");
    sb.AppendLine(autopilotEnabled ? "State: Enabled" : "State: Disabled");
    if (hasTarget)
        sb.AppendLine($"Target: {targetPosition.ToString("0.00")}");
    else
        sb.AppendLine("Target: <none>");
    sb.AppendLine($"Runtime (last tick): {Runtime.LastRunTimeMs:0.000} ms");
    sb.AppendLine($"Runtime peak (last minute): {runtimePeakLastMinuteMs:0.000} ms");
    Echo(sb.ToString());
}

void UpdateRuntimeMetrics()
{
    double lastTickMs = Runtime.LastRunTimeMs;
    if (lastTickMs > runtimePeakLastMinuteMs)
        runtimePeakLastMinuteMs = lastTickMs;

    runtimePeakWindowElapsedSeconds += secondsPerTick;
    if (runtimePeakWindowElapsedSeconds >= 60.0)
    {
        runtimePeakLastMinuteMs = lastTickMs;
        runtimePeakWindowElapsedSeconds = 0;
    }
}

void Move()
{
    Vector3D worldOffset = GetTargetOffsetWorld();
    Vector3D position    = rc.GetPosition() + worldOffset;
    Vector3D toTarget    = targetPosition - position;

    Vector3D forward = desiredForward;
    if (forward == Vector3D.Zero && toTarget.LengthSquared() > 0.001)
        forward = Vector3D.Normalize(toTarget);

    Vector3D up = desiredUp;
    if (up == Vector3D.Zero)
    {
        Vector3D gravity = rc.GetNaturalGravity();
        if (gravity.LengthSquared() > 0.001)
            up = Vector3D.Normalize(-gravity);
        else
            up = rc.WorldMatrix.Up;
    }

    gyros.FaceVectors(forward, up);

    double tolerance = Math.Max(0.05, arrivalTolerance);
    bool atPosition  = toTarget.LengthSquared() < tolerance * tolerance;
    bool aligned     = IsOrientationAligned(forward, up, orientationToleranceDeg);
    if (atPosition)
    {
        thrust.Reset();
        if (aligned)
            gyros.Reset();
        return;
    }

    double maxSpeedNow = activeMaxSpeed > 0 ? activeMaxSpeed : maxSpeed;
    Vector3D rcTarget  = targetPosition - worldOffset;
    thrust.ApplyAccel(thrust.ControlPosition(rcTarget, Vector3D.Zero, maxSpeedNow));
}

Vector3D GetTargetOffsetWorld()
{
    MatrixD wm = rc.WorldMatrix;
    return wm.Right * TOFFR + wm.Up * TOFFU + wm.Forward * TOFFF;
}

bool IsOrientationAligned(Vector3D forward, Vector3D up, double toleranceDeg)
{
    double minDot = Math.Cos(Math.Max(0.1, toleranceDeg) * Math.PI / 180.0);
    MatrixD wm    = rc.WorldMatrix;
    if (forward.LengthSquared() > 0.001 && Vector3D.Dot(wm.Forward, Vector3D.Normalize(forward)) < minDot)
        return false;
    if (up.LengthSquared() > 0.001 && Vector3D.Dot(wm.Up, Vector3D.Normalize(up)) < minDot)
        return false;
    return true;
}

bool IsAtTargetPosition(Vector3D target, double toleranceMeters = -1)
{
    double baseTolerance = toleranceMeters > 0 ? toleranceMeters : arrivalTolerance;
    double tolerance     = Math.Max(0.05, baseTolerance);
    return Vector3D.DistanceSquared(rc.GetPosition() + GetTargetOffsetWorld(), target) < tolerance * tolerance;
}

bool IsAtTargetPose(Vector3D target, Vector3D forward, Vector3D up, double toleranceMeters = -1)
{
    return IsAtTargetPosition(target, toleranceMeters) && IsOrientationAligned(forward, up, orientationToleranceDeg);
}

void RemoteCommand(string command)
{
    if (string.IsNullOrWhiteSpace(command))
        return;

    string trimmed = command.Trim();

    if (trimmed.StartsWith("Nav;", StringComparison.OrdinalIgnoreCase))
    {
        string navArgs = trimmed.Substring(4).Trim();
        if (!TryParseGpsCommand(navArgs, out targetPosition, out desiredForward, out desiredUp))
        {
            Echo("Invalid Nav command. Use: Nav;GPS:Name:X:Y:Z:|Faceup,Faceforward");
            return;
        }
        hasTarget        = true;
        autopilotEnabled = true;
        Runtime.UpdateFrequency = tickSpeed;
        WriteEcho();
        return;
    }

    if (trimmed.StartsWith("TOFF ", StringComparison.OrdinalIgnoreCase))
    {
        Vector3D off;
        if (TryParseVector3(trimmed.Substring(5).Trim(), out off))
        {
            TOFFR = off.X; TOFFU = off.Y; TOFFF = off.Z;
            Echo($"TOFF set. R/U/F = {TOFFR:0.00}/{TOFFU:0.00}/{TOFFF:0.00} m");
        }
        else
            Echo("Invalid TOFF. Use: TOFF r,u,f");
        return;
    }

    if (trimmed.StartsWith("loadasteroid ", StringComparison.OrdinalIgnoreCase))
    {
        LoadAsteroid(trimmed);
        return;
    }

    if (trimmed.StartsWith("goto ", StringComparison.OrdinalIgnoreCase))
    {
        HandleGoTo(trimmed);
        return;
    }
    if (trimmed.StartsWith("mine ", StringComparison.OrdinalIgnoreCase))
    {
        StartMineSequence(trimmed);
        return;
    }
    if (TryHandleOreNameStateCommand(trimmed))
        return;
    switch (trimmed.ToLower())
    {
        case "stop":
            Runtime.UpdateFrequency = UpdateFrequency.None;
            ResetMovement();
            autopilotEnabled = false;
            Echo("Stopped.");
            break;
        case "start":
            Runtime.UpdateFrequency = tickSpeed;
            autopilotEnabled = true;
            WriteEcho();
            break;
        case "clear":
        case "reset":
            hasTarget           = false;
            desiredForward      = Vector3D.Zero;
            desiredUp           = Vector3D.Zero;
            goToMode            = false;
            goToStage           = 0;
            mineSequenceState   = MineSequenceState.None;
            mineAsteroidNum     = 0;
            minerPathCompleteReceived = false;
            mineStationaryTicks = 0;
            pathMode            = false;
            pathPaused          = false;
            pathPausedNavResume = false;
            pathRecords.Clear();
            pathIndex           = 0;
            activeMaxSpeed      = 0;
            ResetMovement();
            WriteEcho();
            break;
        case "dumpgps":
            DumpCurrentGpsToCustomData();
            break;
        case "pathstart":
            StartPathFromTimer();
            break;
        case "pathpause":
            if (!pathMode)
                Echo("Path mode is not active.");
            else
            {
                pathPaused = true;
                if (autopilotEnabled && hasTarget)
                {
                    autopilotEnabled    = false;
                    pathPausedNavResume = true;
                    Echo("Path mode paused. Movement halted.");
                }
                else
                    Echo("Path mode paused.");
            }
            break;
        case "pathcontinue":
            if (!pathMode)
                Echo("Path mode is not active.");
            else
            {
                pathPaused = false;
                Echo("Path mode resumed.");
                if (pathPausedNavResume && hasTarget)
                {
                    autopilotEnabled    = true;
                    pathPausedNavResume = false;
                }
                else if (!autopilotEnabled)
                    StartNextPathRecord();
            }
            break;
        case "pathstop":
            pathMode            = false;
            pathPaused          = false;
            pathPausedNavResume = false;
            pathRecords.Clear();
            pathIndex = 0;
            Echo("Path mode stopped.");
            break;
        case "toffreset":
            TOFFR = 0; TOFFU = 0; TOFFF = 0;
            Echo("TOFF reset to 0,0,0.");
            break;
        case "saveasteroid":
            SaveAsteroid();
            break;
        case "setallopen":
            SetAllAsteroidsOpen();
            break;
        case "fullauto":
            fullAutoEnabled = true;
            fullAutoWaitingForMine = false;
            fullAutoCooldownTicks = 0;
            fullAutoActiveAsteroid = 0;
            Echo("Fullauto: enabled.");
            break;
        case "fullautostop":
            fullAutoEnabled = false;
            fullAutoWaitingForMine = false;
            fullAutoCooldownTicks = 0;
            fullAutoActiveAsteroid = 0;
            Echo("Fullauto: stopped.");
            break;
    }
}

void UpdatePathRunner()
{
    if (!pathMode || pathRecords.Count == 0) return;
    if (pathPaused) return;

    if (autopilotEnabled && hasTarget)
    {
        if (IsAtTargetPose(targetPosition, desiredForward, desiredUp))
        {
            autopilotEnabled = false;
            hasTarget        = false;
            activeMaxSpeed   = 0;
        }
        return;
    }

    StartNextPathRecord();
}

void PollMinerPathCompletion()
{
    if (minerPathCompleteListener == null)
        return;

    while (minerPathCompleteListener.HasPendingMessage)
    {
        MyIGCMessage msg = minerPathCompleteListener.AcceptMessage();
        string payload = msg.Data as string;
        if (!string.IsNullOrWhiteSpace(payload))
            Echo($"Miner broadcast: {payload}");
        minerPathCompleteReceived = true;
    }
}

void StartMineSequence(string argument)
{
    string[] parts = argument.Split(new[] { ' ' }, 2, StringSplitOptions.RemoveEmptyEntries);
    if (parts.Length < 2)
    {
        Echo("Usage: Mine <number>  e.g. Mine 032");
        return;
    }

    int asteroidNum;
    if (!int.TryParse(parts[1].Trim(), out asteroidNum) || asteroidNum < 1)
    {
        Echo($"Mine: invalid number '{parts[1].Trim()}'.");
        return;
    }

    string asteroidStatus;
    if (TryGetAsteroidStatus(asteroidNum, out asteroidStatus))
    {
        string normalized = asteroidStatus.Trim().ToLowerInvariant();
        if (normalized == "complete" || normalized == "completed")
        {
            Echo($"Mine: asteroid {asteroidNum:D3} is already marked '{asteroidStatus}'. Aborting.");
            return;
        }
    }
    else
        Echo($"Mine: asteroid {asteroidNum:D3} has no status entry in Zone DB. Proceeding.");

    Vector3D savedPos, savedForward, savedUp;
    if (!TryGetCarrierPoseFromZoneDb(asteroidNum, out savedPos, out savedForward, out savedUp))
    {
        Echo($"Mine: asteroid {asteroidNum:D3} not found in Zone DB.");
        return;
    }
    if (savedForward.LengthSquared() < 0.001 || savedUp.LengthSquared() < 0.001)
    {
        Echo($"Mine: asteroid {asteroidNum:D3} saved carrier orientation is invalid.");
        return;
    }

    mineAsteroidNum = asteroidNum;
    mineSavedPos = savedPos;
    mineSavedForward = savedForward;
    mineSavedUp = savedUp;
    mineFrontApproachPoint = savedPos + savedForward * goToLeadDistanceMeters;
    minerPathCompleteReceived = false;
    mineStationaryTicks = 0;

    HandleGoTo("GoTo " + asteroidNum.ToString("D3"));
    if (!goToMode)
    {
        Echo("Mine: unable to start GoTo.");
        return;
    }

    mineSequenceState = MineSequenceState.GoingTo;
    Echo($"Mine: sequence started for asteroid {asteroidNum:D3}.");
}

void UpdateMineSequence()
{
    if (mineSequenceState == MineSequenceState.None)
        return;

    if (mineSequenceState == MineSequenceState.GoingTo)
    {
        if (goToMode)
            return;

        mineSequenceState = MineSequenceState.WaitingForStationary;
        mineStationaryTicks = 0;
        Echo($"Mine: GoTo complete. Waiting to be stationary before starting miner for asteroid {mineAsteroidNum:D3}.");
        return;
    }

    if (mineSequenceState == MineSequenceState.WaitingForStationary)
    {
        double speed = rc.GetShipVelocities().LinearVelocity.Length();
        if (speed <= Math.Max(0, mineStationarySpeedMps))
            mineStationaryTicks++;
        else
            mineStationaryTicks = 0;

        if (mineStationaryTicks < Math.Max(1, mineStationaryConfirmTicks))
            return;

        LoadAsteroid("LoadAsteroid " + mineAsteroidNum.ToString("D3"));
        SendMinerCommand("PathStart");
        mineSequenceState = MineSequenceState.WaitingMinerPathComplete;
        mineStationaryTicks = 0;
        Echo($"Mine: waiting for miner completion broadcast for asteroid {mineAsteroidNum:D3}.");
        return;
    }

    if (mineSequenceState == MineSequenceState.WaitingMinerPathComplete)
    {
        if (!minerPathCompleteReceived)
            return;

        targetPosition = mineFrontApproachPoint;
        desiredForward = mineSavedForward;
        desiredUp = mineSavedUp;
        hasTarget = true;
        autopilotEnabled = true;
        activeMaxSpeed = maxSpeed;
        mineSequenceState = MineSequenceState.ReturningToFrontApproach;
        Echo($"Mine: miner complete. Returning to front approach point for asteroid {mineAsteroidNum:D3}.");
        return;
    }

    if (mineSequenceState == MineSequenceState.ReturningToFrontApproach)
    {
        if (!IsAtTargetPose(mineFrontApproachPoint, mineSavedForward, mineSavedUp))
            return;

        int completedAsteroid = mineAsteroidNum;
        if (TrySetAsteroidStatus(completedAsteroid, "Completed"))
            Echo($"Mine: asteroid {completedAsteroid:D3} status set to Completed.");
        else
            Echo($"Mine: warning - could not set asteroid {completedAsteroid:D3} status to Completed.");

        autopilotEnabled = false;
        hasTarget = false;
        activeMaxSpeed = 0;
        mineSequenceState = MineSequenceState.None;
        mineAsteroidNum = 0;
        minerPathCompleteReceived = false;
        mineStationaryTicks = 0;
        Echo("Mine: sequence complete.");
    }
}

void UpdateFullAuto()
{
    if (!fullAutoEnabled)
        return;

    if (fullAutoCooldownTicks > 0)
    {
        fullAutoCooldownTicks--;
        return;
    }

    if (fullAutoWaitingForMine)
    {
        if (mineSequenceState != MineSequenceState.None)
            return;

        Echo($"Fullauto: asteroid {fullAutoActiveAsteroid:D3} complete.");
        fullAutoWaitingForMine = false;
        fullAutoActiveAsteroid = 0;
        fullAutoCooldownTicks = 30;
        return;
    }

    if (mineSequenceState != MineSequenceState.None)
        return;

    ZoneAsteroidRecord selected;
    string reason;
    if (!TrySelectFullAutoAsteroid(out selected, out reason))
    {
        Echo("Fullauto: " + reason);
        fullAutoCooldownTicks = Math.Max(1, fullAutoRetryTicks);
        return;
    }

    StartMineSequence("Mine " + selected.Number.ToString("D3"));
    if (mineSequenceState == MineSequenceState.None)
    {
        Echo($"Fullauto: Mine {selected.Number:D3} did not start. Retrying later.");
        fullAutoCooldownTicks = Math.Max(1, fullAutoRetryTicks);
        return;
    }

    fullAutoWaitingForMine = true;
    fullAutoActiveAsteroid = selected.Number;
    Echo($"Fullauto: started Mine {selected.Number:D3}.");
}

bool TrySelectFullAutoAsteroid(out ZoneAsteroidRecord selected, out string reason)
{
    selected = null;
    reason = "no eligible asteroid found.";

    IMyTimerBlock zoneDb = FindZoneDbTimer();
    if (zoneDb == null)
    {
        reason = $"Zone DB timer '{zoneDbTimerTag}' not found.";
        return false;
    }

    HashSet<string> enabledOres;
    if (!TryGetEnabledOreSet(out enabledOres, out reason))
        return false;
    if (enabledOres.Count == 0)
    {
        reason = $"no enabled ores in timer '{oreNameTimerTag}'.";
        return false;
    }

    List<ZoneAsteroidRecord> records = ParseZoneDbRecords(zoneDb.CustomData ?? "");
    if (records.Count == 0)
    {
        reason = "Zone DB has no asteroid records.";
        return false;
    }

    Vector3D current = rc.GetPosition();
    ZoneAsteroidRecord best = null;
    double bestDistSq = double.MaxValue;

    foreach (var rec in records)
    {
        if (!string.Equals(rec.Status, "Open", StringComparison.OrdinalIgnoreCase))
            continue;
        if (!RecordHasEnabledOre(rec, enabledOres))
            continue;
        if (!IsFullAutoPathSafe(current, rec, records))
            continue;

        double distSq = Vector3D.DistanceSquared(current, rec.Position);
        if (distSq < bestDistSq)
        {
            bestDistSq = distSq;
            best = rec;
        }
    }

    if (best == null)
    {
        reason = "no Open asteroid matches enabled ores with a safe path.";
        return false;
    }

    selected = best;
    return true;
}

bool TryGetEnabledOreSet(out HashSet<string> enabledOres, out string error)
{
    enabledOres = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    error = "";

    IMyTimerBlock oreTimer = GridTerminalSystem.GetBlockWithName(oreNameTimerTag) as IMyTimerBlock;
    if (oreTimer == null)
    {
        error = $"ore timer '{oreNameTimerTag}' not found.";
        return false;
    }

    string data = oreTimer.CustomData ?? "";
    foreach (string rawLine in data.Split(new[] { '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries))
    {
        string line = rawLine.Trim();
        if (line.Length == 0) continue;
        if (line.StartsWith("//")) continue;

        string[] parts = line.Split(new[] { ' ', '\t' }, StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0) continue;

        bool isOn = parts.Length < 2 || parts[1].Equals("on", StringComparison.OrdinalIgnoreCase);
        if (isOn)
            enabledOres.Add(parts[0].Trim());
    }
    return true;
}

List<ZoneAsteroidRecord> ParseZoneDbRecords(string customData)
{
    var records = new List<ZoneAsteroidRecord>();
    string[] lines = customData.Split(new[] { '\n', '\r' }, StringSplitOptions.None);

    for (int i = 0; i < lines.Length; i++)
    {
        int asteroidNum;
        if (!IsAsteroidLabelLine(lines[i].Trim(), out asteroidNum))
            continue;

        Vector3D pos = Vector3D.Zero, f = Vector3D.Zero, u = Vector3D.Zero;
        string status = "";
        var ores = new List<string>();
        bool hasGps = false;

        for (int j = i + 1; j < lines.Length; j++)
        {
            string t = lines[j].Trim();
            if (string.IsNullOrWhiteSpace(t))
                continue;

            int nextNum;
            if (IsAsteroidLabelLine(t, out nextNum) ||
                t.IndexOf(asteroidDbTagPfx, StringComparison.OrdinalIgnoreCase) >= 0)
                break;

            if (!hasGps && t.StartsWith("GPS:", StringComparison.OrdinalIgnoreCase))
            {
                if (TryParseGpsCommand(t, out pos, out f, out u))
                    hasGps = true;
            }
            else if (t.StartsWith("Ores:", StringComparison.OrdinalIgnoreCase))
            {
                ores = ParseOresLine(t.Substring("Ores:".Length).Trim());
            }
            else if (t.StartsWith("Status:", StringComparison.OrdinalIgnoreCase))
            {
                status = t.Substring("Status:".Length).Trim();
            }
        }

        if (!hasGps)
            continue;

        var rec = new ZoneAsteroidRecord();
        rec.Number = asteroidNum;
        rec.Position = pos;
        rec.Status = status;
        rec.Ores = ores;
        records.Add(rec);
    }

    return records;
}

List<string> ParseOresLine(string oresText)
{
    var ores = new List<string>();
    if (string.IsNullOrWhiteSpace(oresText) || oresText.Equals("(none)", StringComparison.OrdinalIgnoreCase))
        return ores;

    foreach (string token in oresText.Split(new[] { ',' }, StringSplitOptions.RemoveEmptyEntries))
    {
        string ore = token.Trim();
        if (ore.Length > 0)
            ores.Add(ore);
    }
    return ores;
}

bool RecordHasEnabledOre(ZoneAsteroidRecord rec, HashSet<string> enabledOres)
{
    for (int i = 0; i < rec.Ores.Count; i++)
    {
        if (enabledOres.Contains(rec.Ores[i]))
            return true;
    }
    return false;
}

bool IsFullAutoPathSafe(Vector3D from, ZoneAsteroidRecord candidate, List<ZoneAsteroidRecord> allRecords)
{
    for (int i = 0; i < allRecords.Count; i++)
    {
        ZoneAsteroidRecord other = allRecords[i];
        if (other.Number == candidate.Number)
            continue;

        if (SegmentIntersectsSphere(from, candidate.Position, other.Position, goToBubbleRadiusMeters))
            return false;
    }
    return true;
}

void StartPathFromTimer()
{
    List<string> loaded;
    string timerName;
    if (!TryLoadPathRecordsFromTimer(out loaded, out timerName))
    {
        Echo($"Unable to load path records from timer tag '{pathTimerTag}'.");
        return;
    }

    pathRecords         = loaded;
    pathIndex           = 0;
    pathMode            = true;
    pathPaused          = false;
    pathPausedNavResume = false;
    Echo($"Loaded {pathRecords.Count} records from timer '{timerName}'.");
    StartNextPathRecord();
}

void StartNextPathRecord()
{
    while (pathMode && pathIndex < pathRecords.Count)
    {
        string record = pathRecords[pathIndex];
        pathIndex++;
        if (ExecutePathRecord(record))
            return;
        Echo($"Skipping invalid path record #{pathIndex}.");
    }

    if (pathMode && pathIndex >= pathRecords.Count)
    {
        pathMode = false;
        Echo("Path execution complete.");
    }
}

bool ExecutePathRecord(string rawRecord)
{
    if (string.IsNullOrWhiteSpace(rawRecord))
        return false;

    string record = rawRecord.Trim();
    if (record.StartsWith("\"") && record.EndsWith("\"") && record.Length >= 2)
        record = record.Substring(1, record.Length - 2).Trim();
    if (string.IsNullOrWhiteSpace(record))
        return false;

    string navCmd = null;
    if (record.StartsWith("Nav;", StringComparison.OrdinalIgnoreCase))
        navCmd = record.Substring(4).Trim();
    else if (record.StartsWith("GPS:", StringComparison.OrdinalIgnoreCase))
        navCmd = record;

    if (navCmd != null)
    {
        Vector3D gps, forward, up;
        if (!TryParseGpsCommand(navCmd, out gps, out forward, out up))
            return false;
        targetPosition   = gps;
        desiredForward   = forward;
        desiredUp        = up;
        hasTarget        = true;
        autopilotEnabled = true;
        return true;
    }

    return false;
}

bool TryLoadPathRecordsFromTimer(out List<string> records, out string timerName)
{
    records   = new List<string>();
    timerName = "";

    IMyTimerBlock timer = FindPathTimer();
    if (timer == null)
        return false;

    timerName = timer.CustomName;
    string data = timer.CustomData ?? "";
    string[] lines = data.Split(new[] { '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries);
    foreach (string line in lines)
    {
        string rec = line.Trim();
        if (string.IsNullOrWhiteSpace(rec)) continue;
        if (rec.StartsWith("\"") && rec.EndsWith("\"") && rec.Length >= 2)
            rec = rec.Substring(1, rec.Length - 2).Trim();
        if (!string.IsNullOrWhiteSpace(rec))
            records.Add(rec);
    }

    return records.Count > 0;
}

IMyTimerBlock FindPathTimer()
{
    if (_cachedPathTimer != null &&
        _cachedPathTimer.CustomName.IndexOf(pathTimerTag, StringComparison.OrdinalIgnoreCase) >= 0)
        return _cachedPathTimer;
    foreach (var t in GetBlocks<IMyTimerBlock>())
        if (t != null && !string.IsNullOrWhiteSpace(t.CustomName) &&
            t.CustomName.IndexOf(pathTimerTag, StringComparison.OrdinalIgnoreCase) >= 0)
        {
            _cachedPathTimer = t;
            return t;
        }
    _cachedPathTimer = null;
    return null;
}

string FormatCurrentGps(string name)
{
    Vector3D p = rc.GetPosition();
    Vector3D f = Vector3D.Normalize(rc.WorldMatrix.Forward);
    Vector3D u = Vector3D.Normalize(rc.WorldMatrix.Up);
    return $"GPS:{name}:{p.X:0.00}:{p.Y:0.00}:{p.Z:0.00}:|{u.X:0.0000},{u.Y:0.0000},{u.Z:0.0000},{f.X:0.0000},{f.Y:0.0000},{f.Z:0.0000}";
}

void DumpCurrentGpsToCustomData()
{
    StringBuilder sb = new StringBuilder();
    string existing = Me.CustomData ?? "";
    if (!string.IsNullOrWhiteSpace(existing))
        sb.Append(existing.TrimEnd());
    sb.AppendLine();
    sb.AppendLine();
    sb.AppendLine("[AutopilotDump]");
    sb.AppendLine(FormatCurrentGps("Here"));
    Me.CustomData = sb.ToString();
    Echo("Dumped GPS/orientation to Custom Data.");
}

// ---- SaveAsteroid ----

void SaveAsteroid()
{
    Echo("SaveAsteroid: simulating recompile...");
    SimulateRecompile();

    if (rc == null)
    {
        Echo("SaveAsteroid: no remote control found after recompile. Aborting.");
        return;
    }

    // Determine next asteroid number and which DB timer it belongs to
    int asteroidNum   = FindNextAsteroidNumber();
    string label      = asteroidNum.ToString("D3");
    int dbIndex       = (asteroidNum - 1) / asteroidsPerDb + 1;
    string dbTimerName = asteroidDbTagPfx + dbIndex.ToString("D2");

    Echo($"SaveAsteroid: saving Asteroid {label} -> {dbTimerName}");

    // Carrier position and orientation from RC
    string carrierGps = FormatCarrierGps();

    // Ore totals from miner containers
    var oreMap = CollectMinerOre();
    EnsureOreNamesListed(oreMap);

    // Path lines from miner's Path timer
    List<string> pathLines = ReadMinerPathLines();

    // Build the Asteroid Record
    var sb = new StringBuilder();
    sb.AppendLine(asteroidHeaderLine);
    sb.AppendLine("Asteroid " + label);
    sb.AppendLine();
    sb.AppendLine("Carrier pos:");
    sb.AppendLine(carrierGps);
    sb.AppendLine();
    sb.AppendLine("Ore:");
    if (oreMap.Count == 0)
    {
        sb.AppendLine("(none)");
    }
    else
    {
        var oreNames = new List<string>(oreMap.Keys);
        oreNames.Sort(StringComparer.OrdinalIgnoreCase);
        foreach (string ore in oreNames)
        {
            long rounded = (long)Math.Round(oreMap[ore]);
            sb.AppendLine(ore + " " + FormatOreAmount(rounded));
        }
    }
    sb.AppendLine(asteroidHeaderLine);
    foreach (string line in pathLines)
        sb.AppendLine(line);

    // Append record to the Asteroid DB timer
    IMyTimerBlock dbTimer = FindTimerByTag(dbTimerName);
    if (dbTimer == null)
    {
        Echo($"SaveAsteroid: timer '{dbTimerName}' not found. Aborting.");
        return;
    }
    string existingDb = dbTimer.CustomData ?? "";
    if (!string.IsNullOrWhiteSpace(existingDb) && !existingDb.EndsWith("\n"))
        existingDb += "\n";
    dbTimer.CustomData = existingDb + sb.ToString();

    // Update the Zone DB (GPS + ore summary + mined status)
    UpdateZoneDb(asteroidNum, dbTimerName, carrierGps, oreMap);

    Echo($"SaveAsteroid: Asteroid {label} saved. Zone DB updated.");
    SendMinerCommand("PathClear");
}

void EnsureOreNamesListed(Dictionary<string, double> oreMap)
{
    if (oreMap == null || oreMap.Count == 0)
        return;

    IMyTimerBlock oreTimer = GridTerminalSystem.GetBlockWithName(oreNameTimerTag) as IMyTimerBlock;
    if (oreTimer == null)
    {
        Echo($"SaveAsteroid: ore timer '{oreNameTimerTag}' not found. Skipping ore-name update.");
        return;
    }

    string data = oreTimer.CustomData ?? "";
    var knownOreNames = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    foreach (string rawLine in data.Split(new[] { '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries))
    {
        string line = rawLine.Trim();
        if (line.Length == 0) continue;

        string[] parts = line.Split(new[] { ' ', '\t' }, StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0) continue;
        knownOreNames.Add(parts[0].Trim());
    }

    var missingOreNames = new List<string>();
    foreach (string ore in oreMap.Keys)
    {
        if (!knownOreNames.Contains(ore))
            missingOreNames.Add(ore);
    }

    if (missingOreNames.Count == 0)
        return;

    missingOreNames.Sort(StringComparer.OrdinalIgnoreCase);

    var sb = new StringBuilder();
    if (!string.IsNullOrWhiteSpace(data))
    {
        sb.Append(data);
        if (!data.EndsWith("\n"))
            sb.AppendLine();
    }

    foreach (string ore in missingOreNames)
        sb.AppendLine(ore + " on");

    oreTimer.CustomData = sb.ToString();
    Echo($"SaveAsteroid: added {missingOreNames.Count} ore name(s) to '{oreNameTimerTag}'.");
}

bool TryHandleOreNameStateCommand(string command)
{
    string[] parts = command.Split(new[] { ' ', '\t' }, StringSplitOptions.RemoveEmptyEntries);
    if (parts.Length != 2)
        return false;

    string oreName = parts[0].Trim();
    string mode = parts[1].Trim().ToLowerInvariant();
    if (oreName.Length == 0 || (mode != "on" && mode != "off"))
        return false;

    // Avoid hijacking existing single-word commands that happen to end with on/off.
    if (oreName.Equals("fullauto", StringComparison.OrdinalIgnoreCase) ||
        oreName.Equals("autopilot", StringComparison.OrdinalIgnoreCase))
        return false;

    IMyTimerBlock oreTimer = GridTerminalSystem.GetBlockWithName(oreNameTimerTag) as IMyTimerBlock;
    if (oreTimer == null)
    {
        Echo($"Ore state: ore timer '{oreNameTimerTag}' not found.");
        return true;
    }

    var lines = new List<string>((oreTimer.CustomData ?? "").Split('\n'));
    bool updated = false;

    for (int i = 0; i < lines.Count; i++)
    {
        string line = lines[i] ?? "";
        string trimmed = line.Trim();
        if (trimmed.Length == 0 || trimmed.StartsWith("//")) continue;

        string[] rowParts = trimmed.Split(new[] { ' ', '\t' }, StringSplitOptions.RemoveEmptyEntries);
        if (rowParts.Length == 0) continue;

        if (rowParts[0].Equals(oreName, StringComparison.OrdinalIgnoreCase))
        {
            lines[i] = oreName + " " + mode;
            updated = true;
            break;
        }
    }

    if (!updated)
        lines.Add(oreName + " " + mode);

    oreTimer.CustomData = string.Join("\n", lines).Replace("\r", "").TrimEnd();
    Echo($"Ore state: {oreName} set to {mode}.");
    return true;
}

// Refreshes all cached block references, mirroring a script recompile.
void SimulateRecompile()
{
    rc = GridTerminalSystem.GetBlockWithName(carrierRemoteName) as IMyRemoteControl;
    if (rc == null)
        rc = GetBlock<IMyRemoteControl>();

    carrierConnector = GridTerminalSystem.GetBlockWithName(carrierConnectorName) as IMyShipConnector;

    allGyros     = GetBlocks<IMyGyro>().FindAll(b => HasCarrierTag(b));
    allThrusters = GetBlocks<IMyThrust>().FindAll(b => HasCarrierTag(b));
    if (rc != null)
    {
        thrust = new ThrusterControl(rc, tickSpeed, allThrusters);
        gyros  = new GyroControl(rc, tickSpeed, allGyros);
    }

    _cachedPathTimer   = null;
    _cachedZoneDbTimer = null;
    Echo("SaveAsteroid: recompile done.");
}

// Scans all Asteroid DB timers to find the highest saved asteroid number, then returns +1.
int FindNextAsteroidNumber()
{
    int maxNum = 0;
    foreach (var t in GetBlocks<IMyTimerBlock>())
    {
        if (t == null || string.IsNullOrWhiteSpace(t.CustomName)) continue;
        if (t.CustomName.IndexOf(asteroidDbTagPfx, StringComparison.OrdinalIgnoreCase) < 0) continue;
        foreach (string line in (t.CustomData ?? "").Split(new[] { '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries))
        {
            string trimmed = line.Trim();
            if (!trimmed.StartsWith("Asteroid ", StringComparison.OrdinalIgnoreCase)) continue;
            int num;
            if (int.TryParse(trimmed.Substring(9).Trim(), out num) && num > maxNum)
                maxNum = num;
        }
    }
    return maxNum + 1;
}

// Finds a timer block whose name contains the given tag (case-insensitive).
IMyTimerBlock FindTimerByTag(string tag)
{
    foreach (var t in GetBlocks<IMyTimerBlock>())
        if (t != null && !string.IsNullOrWhiteSpace(t.CustomName) &&
            t.CustomName.IndexOf(tag, StringComparison.OrdinalIgnoreCase) >= 0)
            return t;
    return null;
}

// Finds and caches the Zone DB timer.
IMyTimerBlock FindZoneDbTimer()
{
    if (_cachedZoneDbTimer != null &&
        _cachedZoneDbTimer.CustomName.IndexOf(zoneDbTimerTag, StringComparison.OrdinalIgnoreCase) >= 0)
        return _cachedZoneDbTimer;
    _cachedZoneDbTimer = FindTimerByTag(zoneDbTimerTag);
    return _cachedZoneDbTimer;
}

// Returns a GPS string for the carrier's current RC position and orientation.
string FormatCarrierGps()
{
    Vector3D p = rc.GetPosition();
    Vector3D f = Vector3D.Normalize(rc.WorldMatrix.Forward);
    Vector3D u = Vector3D.Normalize(rc.WorldMatrix.Up);
    return "GPS:Carrier:" + p.X.ToString("0.00") + ":" + p.Y.ToString("0.00") + ":" + p.Z.ToString("0.00") +
           ":|" + u.X.ToString("0.0000") + "," + u.Y.ToString("0.0000") + "," + u.Z.ToString("0.0000") +
           "," + f.X.ToString("0.0000") + "," + f.Y.ToString("0.0000") + "," + f.Z.ToString("0.0000");
}

// Formats a non-negative integer with dots as thousands separators (e.g. 9343432 -> "9.343.432").
string FormatOreAmount(long amount)
{
    string raw = amount.ToString();
    if (raw.Length <= 3) return raw;
    var result = new StringBuilder();
    int start = raw.Length % 3;
    if (start > 0) result.Append(raw.Substring(0, start));
    for (int i = start; i < raw.Length; i += 3)
    {
        if (result.Length > 0) result.Append('.');
        result.Append(raw.Substring(i, 3));
    }
    return result.ToString();
}

// Scans all blocks on the grid whose names contain minerContainerTag for ore items.
// Returns a map of ore subtype -> total amount, excluding Stone.
Dictionary<string, double> CollectMinerOre()
{
    var result = new Dictionary<string, double>(StringComparer.OrdinalIgnoreCase);
    var blocks = new List<IMyTerminalBlock>();
    var items  = new List<MyInventoryItem>();

    GridTerminalSystem.GetBlocksOfType(blocks, b =>
        b.CubeGrid.EntityId == Me.CubeGrid.EntityId &&
        b.CustomName.IndexOf(minerContainerTag, StringComparison.OrdinalIgnoreCase) >= 0 &&
        b.HasInventory);

    foreach (var block in blocks)
    {
        if (!block.IsFunctional) continue;
        for (int i = 0; i < block.InventoryCount; i++)
        {
            var inv = block.GetInventory(i);
            if (inv == null) continue;
            items.Clear();
            inv.GetItems(items);
            foreach (var item in items)
            {
                if (!string.Equals(item.Type.TypeId, "MyObjectBuilder_Ore", StringComparison.OrdinalIgnoreCase))
                    continue;
                string sub = item.Type.SubtypeId;
                if (string.Equals(sub, "Stone", StringComparison.OrdinalIgnoreCase))
                    continue;
                double cur;
                result.TryGetValue(sub, out cur);
                result[sub] = cur + (double)item.Amount;
            }
        }
    }
    return result;
}

// Finds and returns the miner's Path timer block (null if not found).
IMyTimerBlock FindMinerPathTimer()
{
    foreach (var t in GetBlocks<IMyTimerBlock>())
    {
        if (t == null || string.IsNullOrWhiteSpace(t.CustomName)) continue;
        if (t.CustomName.IndexOf(minerPathTimerTag, StringComparison.OrdinalIgnoreCase) >= 0)
            return t;
    }
    return null;
}

// Reads and returns all non-empty lines from the miner's Path timer custom data.
List<string> ReadMinerPathLines()
{
    var lines = new List<string>();
    IMyTimerBlock timer = FindMinerPathTimer();
    if (timer == null)
    {
        Echo($"SaveAsteroid: miner path timer '{minerPathTimerTag}' not found.");
        return lines;
    }
    foreach (string line in (timer.CustomData ?? "").Split(new[] { '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries))
    {
        string trimmed = line.Trim();
        if (!string.IsNullOrWhiteSpace(trimmed))
            lines.Add(trimmed);
    }
    return lines;
}

// Sends a command string to the miner's programmable block.
void SendMinerCommand(string command)
{
    var allPbs = new List<IMyProgrammableBlock>();
    GridTerminalSystem.GetBlocksOfType(allPbs);
    foreach (var pb in allPbs)
    {
        if (pb == Me) continue;
        if (pb.CustomName.IndexOf(minerPbTag, StringComparison.OrdinalIgnoreCase) >= 0)
        {
            pb.TryRun(command);
            Echo($"Sent '{command}' to '{pb.CustomName}'.");
            return;
        }
    }
    Echo($"SendMinerCommand: miner PB '{minerPbTag}' not found.");
}

// Loads the path records of a saved asteroid into the miner's Path timer.
// Usage: LoadAsteroid 002
void LoadAsteroid(string argument)
{
    string[] parts = argument.Split(new[] { ' ' }, 2, StringSplitOptions.RemoveEmptyEntries);
    if (parts.Length < 2)
    {
        Echo("Usage: LoadAsteroid <number>  e.g. LoadAsteroid 002");
        return;
    }
    int asteroidNum;
    if (!int.TryParse(parts[1].Trim(), out asteroidNum) || asteroidNum < 1)
    {
        Echo($"LoadAsteroid: invalid number '{parts[1].Trim()}'.");
        return;
    }
    string label = asteroidNum.ToString("D3");

    int dbIndex = (asteroidNum - 1) / asteroidsPerDb + 1;
    string dbTimerName = asteroidDbTagPfx + dbIndex.ToString("D2");
    IMyTimerBlock dbTimer = FindTimerByTag(dbTimerName);
    if (dbTimer == null)
    {
        Echo($"LoadAsteroid: DB timer '{dbTimerName}' not found.");
        return;
    }

    List<string> pathLines = ExtractAsteroidPathLines(dbTimer.CustomData ?? "", asteroidNum);
    if (pathLines.Count == 0)
    {
        Echo($"LoadAsteroid: no path data found for Asteroid {label} in '{dbTimerName}'.");
        return;
    }

    IMyTimerBlock pathTimer = FindMinerPathTimer();
    if (pathTimer == null)
    {
        Echo($"LoadAsteroid: miner path timer '{minerPathTimerTag}' not found.");
        return;
    }

    var sb = new StringBuilder();
    foreach (string line in pathLines)
        sb.AppendLine(line);
    pathTimer.CustomData = sb.ToString();

    Echo($"LoadAsteroid: Asteroid {label} loaded to miner path timer ({pathLines.Count} records).");
}

void HandleGoTo(string argument)
{
    string[] parts = argument.Split(new[] { ' ' }, 2, StringSplitOptions.RemoveEmptyEntries);
    if (parts.Length < 2)
    {
        Echo("Usage: GoTo <number>  e.g. GoTo 032");
        return;
    }

    int asteroidNum;
    if (!int.TryParse(parts[1].Trim(), out asteroidNum) || asteroidNum < 1)
    {
        Echo($"GoTo: invalid number '{parts[1].Trim()}'.");
        return;
    }

    Vector3D savedPos, savedForward, savedUp;
    if (!TryGetCarrierPoseFromZoneDb(asteroidNum, out savedPos, out savedForward, out savedUp))
    {
        Echo($"GoTo: asteroid {asteroidNum:D3} not found in Zone DB.");
        return;
    }

    if (savedForward.LengthSquared() < 0.001 || savedUp.LengthSquared() < 0.001)
    {
        Echo($"GoTo: asteroid {asteroidNum:D3} saved carrier orientation is invalid.");
        return;
    }

    Vector3D currentPos = rc.GetPosition();
    Vector3D frontPoint = savedPos + savedForward * goToLeadDistanceMeters;
    Vector3D backPoint  = savedPos - savedForward * goToLeadDistanceMeters;
    Vector3D bubbleCenter = savedPos - savedUp * goToBubbleOffsetMeters;

    bool frontIntersects = SegmentIntersectsSphere(currentPos, frontPoint, bubbleCenter, goToBubbleRadiusMeters);
    bool backIntersects  = SegmentIntersectsSphere(currentPos, backPoint, bubbleCenter, goToBubbleRadiusMeters);

    if (frontIntersects && backIntersects)
    {
        Echo($"GoTo: both approach lines intersect asteroid bubble (r={goToBubbleRadiusMeters:0}).");
        return;
    }

    Vector3D chosenPoint = frontIntersects ? backPoint : frontPoint;
    targetPosition   = chosenPoint;
    desiredForward   = Vector3D.Zero;
    desiredUp        = savedUp;
    hasTarget        = true;
    autopilotEnabled = true;
    Runtime.UpdateFrequency = tickSpeed;
    goToMode         = true;
    goToStage        = 1;
    pathMode         = false;
    pathPaused       = false;
    pathPausedNavResume = false;
    pathRecords.Clear();
    pathIndex = 0;

    _goToFinalPosition = savedPos;
    _goToFinalForward  = savedForward;
    _goToFinalUp       = savedUp;

    Echo($"GoTo: Asteroid {asteroidNum:D3} using {(frontIntersects ? "rear" : "front")} approach point.");
}

Vector3D _goToFinalPosition = Vector3D.Zero;
Vector3D _goToFinalForward  = Vector3D.Zero;
Vector3D _goToFinalUp       = Vector3D.Zero;

void UpdateGoToRunner()
{
    if (!goToMode || !autopilotEnabled || !hasTarget)
        return;

    if (goToStage == 1 && IsAtTargetPosition(targetPosition))
    {
        targetPosition = _goToFinalPosition;
        desiredForward = _goToFinalForward;
        desiredUp      = _goToFinalUp;
        goToStage      = 2;
        Echo("GoTo: side-point reached. Starting final approach.");
        return;
    }

    if (goToStage == 2 && IsAtTargetPose(_goToFinalPosition, _goToFinalForward, _goToFinalUp))
    {
        goToMode      = false;
        goToStage     = 0;
        Echo("GoTo: final pose reached.");
    }
}

bool TryGetCarrierPoseFromZoneDb(int asteroidNum, out Vector3D pos, out Vector3D forward, out Vector3D up)
{
    pos = Vector3D.Zero;
    forward = Vector3D.Zero;
    up = Vector3D.Zero;

    IMyTimerBlock zoneDb = FindZoneDbTimer();
    if (zoneDb == null)
        return false;

    string[] lines = (zoneDb.CustomData ?? "").Split(new[] { '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries);
    string label = asteroidNum.ToString("D3");
    for (int i = 0; i < lines.Length - 1; i++)
    {
        if (!string.Equals(lines[i].Trim(), label, StringComparison.OrdinalIgnoreCase))
            continue;

        Vector3D gps, f, u;
        if (TryParseGpsCommand(lines[i + 1].Trim(), out gps, out f, out u))
        {
            pos = gps;
            forward = f;
            up = u;
            return true;
        }
    }
    return false;
}

bool SegmentIntersectsSphere(Vector3D a, Vector3D b, Vector3D center, double radius)
{
    Vector3D ab = b - a;
    double abLenSq = ab.LengthSquared();
    if (abLenSq < 1e-6)
        return Vector3D.DistanceSquared(a, center) <= radius * radius;

    double t = Vector3D.Dot(center - a, ab) / abLenSq;
    t = MathHelper.Clamp(t, 0, 1);
    Vector3D closest = a + ab * t;
    return Vector3D.DistanceSquared(closest, center) <= radius * radius;
}

// Extracts only the path lines for the given asteroid number from a DB timer's CustomData.
// Path lines are stored after the second separator line ("---...") in each asteroid record.
List<string> ExtractAsteroidPathLines(string dbContent, int asteroidNum)
{
    string label = asteroidNum.ToString("D3");
    string[] allLines = dbContent.Split(new[] { '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries);

    var result = new List<string>();
    // state 0: searching for "Asteroid NNN"
    // state 1: found it, waiting for the second --- separator (before path data)
    // state 2: collecting path lines (stop at next ---)
    int state = 0;

    foreach (string rawLine in allLines)
    {
        string line = rawLine.Trim();
        if (string.IsNullOrWhiteSpace(line)) continue;

        if (state == 0)
        {
            if (string.Equals(line, "Asteroid " + label, StringComparison.OrdinalIgnoreCase))
                state = 1;
        }
        else if (state == 1)
        {
            if (line == asteroidHeaderLine)
                state = 2;
        }
        else
        {
            if (line == asteroidHeaderLine)
                break; // start of next asteroid record
            result.Add(line);
        }
    }

    return result;
}

// Appends one asteroid entry to the Zone DB timer.
// A new section header (DB timer name) is inserted whenever a new DB block starts.
// Entry layout:
//   001
//   GPS:Carrier:...
//   Ores: Ice,Iron,Nickel
//   Status: Complete
void UpdateZoneDb(int asteroidNum, string dbTimerName, string carrierGps, Dictionary<string, double> oreMap)
{
    IMyTimerBlock zoneDb = FindZoneDbTimer();
    if (zoneDb == null)
    {
        Echo($"SaveAsteroid: Zone DB timer '{zoneDbTimerTag}' not found. Skipping.");
        return;
    }

    string existing = zoneDb.CustomData ?? "";
    var sb = new StringBuilder();
    if (!string.IsNullOrWhiteSpace(existing))
    {
        sb.Append(existing.TrimEnd());
        sb.AppendLine();
    }

    // Add a blank line + section header when this asteroid opens a new DB timer
    if ((asteroidNum - 1) % asteroidsPerDb == 0)
    {
        if (sb.Length > 0) sb.AppendLine();
        sb.AppendLine(dbTimerName);
    }

    sb.AppendLine(asteroidNum.ToString("D3"));
    sb.AppendLine(carrierGps);
    sb.AppendLine("Ores: " + BuildOreSummary(oreMap));
    sb.AppendLine("Status: " + BuildAsteroidStatus(oreMap));

    zoneDb.CustomData = sb.ToString();
}


string BuildOreSummary(Dictionary<string, double> oreMap)
{
    if (oreMap == null || oreMap.Count == 0)
        return "(none)";

    var oreNames = new List<string>(oreMap.Keys);
    oreNames.Sort(StringComparer.OrdinalIgnoreCase);
    return string.Join(",", oreNames);
}

string BuildAsteroidStatus(Dictionary<string, double> _oreMap)
{
    return "Complete";
}



void SetAllAsteroidsOpen()
{
    IMyTimerBlock zoneDb = FindZoneDbTimer();
    if (zoneDb == null)
    {
        Echo($"SetAllOpen: Zone DB timer '{zoneDbTimerTag}' not found.");
        return;
    }

    var lines = new List<string>((zoneDb.CustomData ?? "").Split('\n'));
    int updated = 0;
    int added = 0;

    // First, normalize any existing status lines.
    for (int i = 0; i < lines.Count; i++)
    {
        string t = lines[i].Trim();
        if (t.StartsWith("Status:", StringComparison.OrdinalIgnoreCase))
        {
            lines[i] = "Status: Open";
            updated++;
        }
    }

    // Then ensure every asteroid entry has a status line.
    for (int i = 0; i < lines.Count; i++)
    {
        int asteroidNum;
        if (!IsAsteroidLabelLine(lines[i].Trim(), out asteroidNum))
            continue;

        int gpsIdx = -1;
        int oresIdx = -1;
        int statusIdx = -1;

        for (int j = i + 1; j < lines.Count; j++)
        {
            string t = lines[j].Trim();
            if (string.IsNullOrWhiteSpace(t))
                continue;

            int nextNum;
            if (IsAsteroidLabelLine(t, out nextNum) ||
                t.IndexOf(asteroidDbTagPfx, StringComparison.OrdinalIgnoreCase) >= 0)
                break;

            if (gpsIdx < 0 && t.StartsWith("GPS:", StringComparison.OrdinalIgnoreCase))
                gpsIdx = j;
            else if (t.StartsWith("Ores:", StringComparison.OrdinalIgnoreCase))
                oresIdx = j;
            else if (t.StartsWith("Status:", StringComparison.OrdinalIgnoreCase))
            {
                statusIdx = j;
                break;
            }
        }

        if (statusIdx >= 0)
            continue;

        int insertAt = oresIdx >= 0 ? oresIdx + 1 : (gpsIdx >= 0 ? gpsIdx + 1 : i + 1);
        lines.Insert(insertAt, "Status: Open");
        added++;
        i = insertAt;
    }

    zoneDb.CustomData = string.Join("\n", lines).TrimEnd();
    Echo($"SetAllOpen: status set to Open (updated {updated}, added {added}).");
}

bool IsAsteroidLabelLine(string line, out int asteroidNum)
{
    asteroidNum = 0;
    if (string.IsNullOrWhiteSpace(line))
        return false;
    if (line.Length != 3)
        return false;
    return int.TryParse(line, out asteroidNum);
}

